# ==========================================
# Django Settings
# ==========================================
DJANGO_SECRET_KEY=change-me-to-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# ==========================================
# Database (внешний PostgreSQL сервер)
# ==========================================
DB_NAME=cert_generator
DB_USER=cert_user
DB_PASSWORD=your_db_password
DB_HOST=192.168.1.100
DB_PORT=5432

# ==========================================
# LDAP Authentication (опционально)
# ==========================================
LDAP_ENABLED=False
LDAP_SERVER_URI=ldap://ldap.example.com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=ldap_password

# User search
LDAP_USER_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_USER_SEARCH_FILTER=(sAMAccountName=%(user)s)

# Attribute mapping
LDAP_ATTR_FIRST_NAME=givenName
LDAP_ATTR_LAST_NAME=sn
LDAP_ATTR_EMAIL=mail

# Groups (опционально)
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
LDAP_STAFF_GROUP=cn=cert_admins,ou=groups,dc=example,dc=com
LDAP_SUPERUSER_GROUP=cn=superadmins,ou=groups,dc=example,dc=com
LDAP_START_TLS=False

# ==========================================
# Email (SMTP)
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=certs@example.com
EMAIL_HOST_PASSWORD=email_password
DEFAULT_FROM_EMAIL=certs@example.com

# Получатели уведомлений (через запятую)
CERT_NOTIFICATION_RECIPIENTS=admin@example.com,support@example.com

# ==========================================
# Celery / Redis
# ==========================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==========================================
# Timezone
# ==========================================
TZ=Europe/Moscow

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=text
