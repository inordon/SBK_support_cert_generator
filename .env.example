# Настройки Telegram бота
BOT_TOKEN=1234567890:AAABBBCCCDDDEEEFFFGGGHHHIIIJJJKKKLLL
ADMIN_USERS=123456789,987654321
VERIFY_USERS=111111111,222222222,333333333
NOTIFICATION_GROUP=-1001234567890

# Настройки базы данных PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=certificates_db
DB_USER=certificates_user
DB_PASSWORD=your_strong_password_here

# Настройки хранилища файлов
CERTIFICATES_PATH=./certificates

# Настройки логирования
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# Общие настройки
DEBUG=false
TIMEZONE=Europe/Moscow

# Дополнительные настройки резервного копирования (опционально)
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
MAX_BACKUP_FILES=30

# Настройки email (опционально)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_REQUEST_TO=certificates@yourcompany.com
# JSON-список разрешенных отправителей запросов: [{"name": "Иванов И.И.", "email": "ivanov@company.com"}]
EMAIL_ALLOWED_SENDERS=[]

# Настройки веб-сервиса (опционально)
WEB_ENABLED=false
WEB_HOST=0.0.0.0
WEB_PORT=8443
WEB_SECRET_KEY=change-me-in-production-use-random-string
# JSON-список пользователей: [{"username": "admin", "password": "secret", "role": "admin", "name": "Администратор"}]
# role: "admin" - полный доступ, "verify" - только просмотр и проверка
WEB_USERS=[]